# Copy this file to .env and adjust the values before running docker compose.

# ── JWT secret ────────────────────────────────────────────────────────────────
# Change this to a long random string in any non-local deployment.
SBOMSHIELD_SECRET=sbomshield-dev-secret-change-in-prod

# ── Repos directory ───────────────────────────────────────────────────────────
# Absolute path to the folder on your machine that contains the projects you
# want to scan.  The container will see this directory as /repos.
#
# Linux / macOS:
#   REPOS_HOST_PATH=/home/yourname/projects
#
# Windows (use forward slashes or the Docker Desktop path format):
#   REPOS_HOST_PATH=C:/Users/YourName/projects
#
# Default (a ./repos folder next to docker-compose.yml — works on all OSes):
REPOS_HOST_PATH=./repos

# ── VulDB API key (optional) ──────────────────────────────────────────────────
# When set, SBOM-Shield queries vuldb.com for additional vulnerability data,
# including ICS/SCADA CVEs published before NVD and exploit availability flags.
# Get a key at https://vuldb.com/?userinfo.api — free tier is sufficient.
# Leave blank (or unset) to disable VulDB enrichment.
VULDB_API_KEY=
